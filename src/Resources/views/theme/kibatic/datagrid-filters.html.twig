{% set has_advanced = false %}
{% for field in form %}
    {% if field.vars.row_attr['data-filter-advanced'] is defined %}{% set has_advanced = true %}{% endif %}
{% endfor %}

<div class="datagrid-filters" data-controller="filters-collapse">
    <div class="datagrid-filters-head">
        <span class="datagrid-filters-title">{{ 'Filters'|trans({}, 'KibaticDatagridBundle') }}</span>

        {% if has_advanced %}
            <button type="button" class="datagrid-filters-toggle" data-action="filters-collapse#toggle">
                <span class="filters-toggle-label filters-toggle-more">
                    {{ 'More filters'|trans({}, 'KibaticDatagridBundle') }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6l6 -6" /></svg>
                </span>
                <span class="filters-toggle-label filters-toggle-less">
                    {{ 'Fewer filters'|trans({}, 'KibaticDatagridBundle') }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 15l6 -6l6 6" /></svg>
                </span>
            </button>
        {% endif %}
    </div>

    {{ form_start(form) }}
    <div class="datagrid-filters-row">
        <div class="datagrid-filters-fields">
            {% for field in form %}
                {% if field.vars.block_prefixes[0] != 'button' and field.vars.row_attr['data-filter-advanced'] is not defined %}
                    {{ form_row(field) }}
                {% endif %}
            {% endfor %}
        </div>

        <div class="datagrid-filters-actions">
            <button type="submit" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16v2.172a2 2 0 0 1 -.586 1.414l-4.414 4.414v7l-6 2v-8.5l-4.48 -4.928a2 2 0 0 1 -.52 -1.345v-2.172z" /></svg>
                {{ 'Filter'|trans({}, 'KibaticDatagridBundle') }}
            </button>

            <a href="{{ datagrid_reset_url(form) }}" class="btn btn-ghost">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 11a8.1 8.1 0 0 0 -15.5 -2m-.5 -4v4h4" /><path d="M4 13a8.1 8.1 0 0 0 15.5 2m.5 4v-4h-4" /></svg>
                {{ 'Reset'|trans({}, 'KibaticDatagridBundle') }}
            </a>
        </div>
    </div>

    {% if has_advanced %}
        <div class="datagrid-filters-advanced">
            {% for field in form %}
                {% if field.vars.row_attr['data-filter-advanced'] is defined %}
                    {{ form_row(field) }}
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}
    {{ form_end(form, {render_rest: false}) }}
</div>
