{#
    Colonne enum_badge — rend une valeur (enum de préférence) en badge coloré.

    Paramètres de colonne :
      - variant : closure fn(value, item) => 'success'|'warning'|'danger'|'info'|'brand'|'neutral'
                  (gère des conditions complexes). Défaut : 'neutral'.
      - dot     : bool, affiche la pastille de couleur en préfixe. Défaut : false.

    Le libellé vient de value.label (enum avec méthode label()), sinon value.name, sinon la valeur.
#}
{% if value is not null %}
    {% set variant = parameters.variant is defined ? datagrid_call(parameters.variant, value, item) : 'neutral' %}
    {% set dot = parameters.dot ?? false %}
    {% set label = attribute(value, 'label') is defined ? value.label : (value.name ?? value) %}

    <span class="badge{% if variant and variant != 'neutral' %} badge-{{ variant }}{% endif %}{% if dot %} badge-dot{% endif %}">{{ label|trans }}</span>
{% endif %}
